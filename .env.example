# index — environment  (TEMPLATE — copy to .env.local and fill in; never put real keys here)
#
# NOTHING here is required to run end-to-end. With no vars set, the data layer
# serves labeled SNAPSHOT fixtures so the whole app works offline. Keys only
# upgrade snapshot data to live data. Put real values in .env.local (git-ignored).

# --- Live Renaiss data (optional) ---
# Without RENAISS_API_URL, tools return data_kind: "snapshot".
# Base URL + key come from the Renaiss hackathon CLI / Discord.
RENAISS_API_URL=
RENAISS_API_KEY=

# --- Curator chat agent (optional) ---
# Only used by the /api/curator chat route, NOT by the dashboard.
ANTHROPIC_API_KEY=

# --- On-chain Merkle verification (optional, future) ---
# When wired, a BscScan key + the gacha pool contract address let
# verify_merkle_proof do a real on-chain root check. Until then it honestly
# reports match: null.
BSCSCAN_API_KEY=
RENAISS_POOL_CONTRACT=

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
